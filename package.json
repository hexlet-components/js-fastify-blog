{
  "name": "javascript-fastify-blog",
  "version": "0.1.0",
  "type": "module",
  "description": "javascript-fastify-blog",
  "engines": {
    "node": ">=26.0"
  },
  "scripts": {
    "migrate": "sequelize db:migrate --config config/config.cjs --migrations-path server/db/migrations --models-path server/db/models --seeders-path server/db/seeders",
    "prebuild": "rm -rf dist",
    "build": "webpack",
    "pretest": "sequelize db:migrate:undo --config config/config.cjs --migrations-path server/db/migrations --models-path server/db/models --seeders-path server/db/seeders && npm run migrate",
    "test": "vitest run",
    "lint": "biome check .",
    "prestart": "npm run migrate",
    "start": "fastify start -a 0.0.0.0 -p 8080 server/plugin.js -l debug -P -o",
    "predev": "npm run migrate",
    "dev": "fastify start -a 0.0.0.0 -p 8080 server/plugin.js -l debug -P -o"
  },
  "author": "Stanislav Dzisiak",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexlet-boilerplates/javascript-fastify-blog.git"
  },
  "bugs": {
    "url": "https://github.com/hexlet-boilerplates/javascript-fastify-blog/issues"
  },
  "homepage": "https://github.com/hexlet-boilerplates/javascript-fastify-blog.git#readme",
  "dependencies": {
    "@fastify/flash": "^5.1.0",
    "@fastify/formbody": "^7.4.0",
    "@fastify/secure-session": "^7.5.1",
    "@fastify/sensible": "^5.5.0",
    "@fastify/static": "^7.0.3",
    "@fastify/view": "^9.0.0",
    "@rails/ujs": "^7.1.3-2",
    "@vscode/sqlite3": "^5.1.2",
    "bootstrap": "^5.3.3",
    "concurrently": "^8.2.2",
    "fastify": "^4.26.2",
    "fastify-cli": "^6.1.1",
    "fastify-error-page": "^4.0.0",
    "fastify-method-override": "^1.5.10",
    "fastify-objectionjs": "^2.0.1",
    "fastify-reverse-routes": "^3.0.0",
    "i18next": "^23.11.2",
    "jquery": "^3.7.1",
    "jstransformer-markdown-it": "^3.0.0",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "mini-css-extract-plugin": "^2.9.0",
    "npm-check-updates": "^16.14.18",
    "objection": "^3.1.4",
    "objection-unique": "^1.2.2",
    "pg": "^8.11.5",
    "pino-pretty": "^11.0.0",
    "pug": "^3.0.2",
    "qs": "^6.12.1",
    "sequelize": "^6.37.3",
    "sequelize-cli": "^6.6.2",
    "sqlite3": "^5.1.7",
    "webpack": "^5.91.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^20.12.7",
    "css-loader": "^7.1.1",
    "dotenv": "^16.4.5",
    "pino-pretty": "^11.0.0",
    "style-loader": "^4.0.0",
    "vitest": "^4.0.15",
    "webpack-cli": "^5.1.4"
  },
  "overrides": {
    "better-sqlite3": "^12.2.0"
  }
}
