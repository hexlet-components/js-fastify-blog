{
   "name": "javascript-fastify-blog",
   "version": "0.1.0",
   "type": "module",
   "description": "javascript-fastify-blog",
   "engines": {
      "node": ">=20.x"
   },
   "scripts": {
      "migrate": "sequelize db:migrate",
      "prebuild": "rm -rf dist",
      "build": "webpack",
      "pretest": "sequelize db:migrate:undo && npm run migrate",
      "test": "jest --verbose --runInBand",
      "prestart": "npm run migrate",
      "start": "fastify start -a 0.0.0.0 -p 8080 server/plugin.js -l debug -P -o",
      "predev": "npm run migrate",
      "dev": "fastify start -a 0.0.0.0 -p 8080 server/plugin.js -l debug -P -o"
   },
   "jest": {
      "modulePathIgnorePatterns": [
         "<rootDir>/__tests__/helpers/"
      ],
      "setupFiles": [
         "dotenv/config"
      ]
   },
   "author": "Stanislav Dzisiak",
   "license": "ISC",
   "repository": {
      "type": "git",
      "url": "git+https://github.com/hexlet-boilerplates/javascript-fastify-blog.git"
   },
   "bugs": {
      "url": "https://github.com/hexlet-boilerplates/javascript-fastify-blog/issues"
   },
   "homepage": "https://github.com/hexlet-boilerplates/javascript-fastify-blog.git#readme",
   "dependencies": {
      "@fastify/flash": "^6.0.3",
      "@fastify/formbody": "^8.0.2",
      "@fastify/secure-session": "^8.3.0",
      "@fastify/sensible": "^6.0.4",
      "@fastify/static": "^9.1.3",
      "@fastify/view": "^11.1.1",
      "@rails/ujs": "^7.1.3-4",
      "@vscode/sqlite3": "^5.1.2",
      "bootstrap": "^5.3.8",
      "concurrently": "^9.2.1",
      "fastify": "^5.8.5",
      "fastify-cli": "^8.0.0",
      "fastify-error-page": "^4.0.0",
      "fastify-method-override": "^1.5.10",
      "fastify-objectionjs": "^2.0.1",
      "fastify-reverse-routes": "^3.0.0",
      "i18next": "^26.2.0",
      "jquery": "^4.0.0",
      "jstransformer-markdown-it": "^3.0.0",
      "knex": "^3.2.10",
      "lodash": "^4.17.21",
      "mini-css-extract-plugin": "^2.10.2",
      "npm-check-updates": "^22.2.0",
      "objection": "^3.1.5",
      "objection-unique": "^1.2.2",
      "pg": "^8.21.0",
      "pino-pretty": "^13.1.3",
      "pug": "^3.0.4",
      "qs": "^6.15.2",
      "sequelize": "^6.37.8",
      "sequelize-cli": "^6.6.5",
      "sqlite3": "^6.0.1",
      "webpack": "^5.106.2"
   },
   "devDependencies": {
      "@eslint/eslintrc": "^3.3.5",
      "@eslint/js": "^10.0.1",
      "@jest/globals": "^30.4.1",
      "@types/jest": "^30.0.0",
      "@types/node": "^25.9.0",
      "css-loader": "^7.1.4",
      "dotenv": "^17.4.2",
      "eslint": "^10.4.0",
      "eslint-config-airbnb-base": "^15.0.0",
      "eslint-plugin-import": "^2.32.0",
      "globals": "^17.6.0",
      "jest": "^30.4.2",
      "jest-cli": "^30.4.2",
      "pino-pretty": "^13.1.3",
      "style-loader": "^4.0.0",
      "webpack-cli": "^7.0.2"
   }
}
